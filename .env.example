# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend)
RESEND_API_KEY=
# RESEND_FROM=PotroNET <noreply@yourdomain.com>

# Cloudflare R2 (direct-to-bucket uploads)
# Account ID from Cloudflare dashboard
R2_ACCOUNT_ID=
# Access key pair scoped to the bucket below (Object Read & Write)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Bucket name
R2_BUCKET_NAME=potronet-media
# Public base URL served from the bucket's custom domain (no trailing slash)
R2_PUBLIC_URL=https://cdn.potronet.com
