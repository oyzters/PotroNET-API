{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": ".",
        "declaration": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "baseUrl": ".",
        "paths": {
            "@lib/*": [
                "./lib/*"
            ]
        }
    },
    "include": [
        "api/**/*.ts",
        "lib/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}