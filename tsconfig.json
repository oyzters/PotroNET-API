{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": ".",
        "declaration": true,
        "resolveJsonModule": true,
        "isolatedModules": false,
        "baseUrl": ".",
        "paths": {
            "@lib/*": [
                "./lib/*"
            ]
        }
    },
    "include": [
        "api/**/*.ts",
        "server/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}